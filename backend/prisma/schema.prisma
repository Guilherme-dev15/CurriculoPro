// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") // Lê do arquivo .env
}

// Modelo de Usuário atualizado
model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String
  password_hash String
  plan          String   @default("free") // Campo do plano de monetização
  documents     Document[] // Relação: Um usuário pode ter vários documentos
}

// Modelo de Documento
model Document {
  id            Int      @id @default(autoincrement())
  type          String   // "resume" ou "cover_letter"
  name          String
  data          Json     // Armazenará o JSON completo dos dados do currículo/carta
  lastModified  DateTime @updatedAt // Atualiza automaticamente a cada alteração
  createdAt     DateTime @default(now()) // Define a data de criação automaticamente

  // Relação com o usuário (Chave estrangeira)
  owner         User     @relation(fields: [ownerId], references: [id])
  ownerId       Int      // Campo que armazena o ID do usuário dono

  // --- CAMPOS DE COMPARTILHAMENTO ATUALIZADOS ---
  isPublic      Boolean  @default(false)
  // CORREÇÃO: Renomeado de 'publicUrl' para 'publicId' e tornado @unique
  publicId      String?  @unique // URL pública única, se aplicável

  // --- RELAÇÃO COM ANALYTICS ---
  // Um documento pode ter vários eventos de visualização
  views         ViewEvent[]
}

// --- NOVO MODELO PARA ANALYTICS ---
model ViewEvent {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  
  // Relação com o documento que foi visto
  document  Document @relation(fields: [documentId], references: [id])
  documentId Int
}