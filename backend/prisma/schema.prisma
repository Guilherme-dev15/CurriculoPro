// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") // Lê do arquivo .env
}

// Modelo de Usuário atualizado
model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String
  password_hash String
  documents     Document[] // Relação: Um usuário pode ter vários documentos
}

// NOVO Modelo de Documento
model Document {
  id            Int      @id @default(autoincrement())
  type          String   // "resume" ou "cover_letter"
  name          String
  data          Json     // Armazenará o JSON completo dos dados do currículo/carta
  lastModified  DateTime @updatedAt // Atualiza automaticamente a cada alteração
  createdAt     DateTime @default(now()) // Define a data de criação automaticamente

  // Relação com o usuário (Chave estrangeira)
  owner         User     @relation(fields: [ownerId], references: [id])
  ownerId       Int      // Campo que armazena o ID do usuário dono
}