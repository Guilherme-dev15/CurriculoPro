// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Ou "postgresql", "mysql", etc.
  url      = env("DATABASE_URL")
}

// Modelo de Utilizador (User)
model User {
  id            Int        @id @default(autoincrement())
  email         String     @unique
  name          String?
  password_hash String
  plan          String     @default("free") // 'free' ou 'pro'
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  documents     Document[] // Relação: Um utilizador tem muitos documentos
}

// Modelo de Documento (Currículo/Carta)
model Document {
  id           Int          @id @default(autoincrement())
  type         String // "resume" ou "cover_letter"
  name         String
  data         Json // Os dados do currículo (JSON)
  isPublic     Boolean      @default(false)
  publicId     String?      @unique // ID para partilha pública (nanoid)
  lastModified DateTime     @default(now()) @updatedAt
  owner        User         @relation(fields: [ownerId], references: [id])
  ownerId      Int // Chave estrangeira para User
  viewEvents   ViewEvent[] // Relação: Um documento tem muitos eventos de visualização

  @@index([ownerId]) // Index para otimizar a busca de documentos por utilizador
}

// Modelo de Evento de Visualização (Analytics)
model ViewEvent {
  id         Int      @id @default(autoincrement())
  timestamp  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId Int // Chave estrangeira para Document

  @@index([documentId]) // Index para otimizar a contagem de views
}